<UserControl x:Class="AppWPF.Resources.Components.CardDefault"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="CardRoot"
             Width="100" Height="150">
    <Border BorderBrush="Black" BorderThickness="2" CornerRadius="8" Background="White">
        <Grid>
            <!-- Valor da carta no canto superior esquerdo -->
            <TextBlock Text="{Binding CardValue, ElementName=CardRoot}" 
                       FontWeight="Bold" FontSize="16" 
                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,4,0,0"/>

            <!-- Imagens do naipe no centro -->
            <ItemsControl ItemsSource="{Binding SuitImages, ElementName=CardRoot}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="4" Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Image Source="{Binding}" Width="20" Height="20" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Valor da carta no canto inferior direito -->
            <TextBlock Text="{Binding CardValue, ElementName=CardRoot}" 
                       FontWeight="Bold" FontSize="16" 
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,4"/>
        </Grid>
    </Border>
</UserControl>